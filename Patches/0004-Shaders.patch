diff --git a/Assets/Shader/BumpSpecDissolve.shader b/Assets/Shader/BumpSpecDissolve.shader
index 885b40e4..ad71468d 100644
--- a/Assets/Shader/BumpSpecDissolve.shader
+++ b/Assets/Shader/BumpSpecDissolve.shader
@@ -1,35 +1,87 @@
 Shader "PC/VFX/BumpSpecDissolve" {
-Properties {
- _Color ("Color", Color) = (1,1,1,1)
- _SpecColor ("Specular Color", Color) = (0.5,0.5,0.5,0)
- _Shininess ("Shininess", Range(0.01,1)) = 0.078125
- _MainTex ("Base (RGB) Gloss(A)", 2D) = "white" { }
- _Normal ("Normal", 2D) = "bump" { }
- _Emissive ("Emissive", 2D) = "black" { }
- _ClipTexture ("ClipTexture", 2D) = "white" { }
- _Clip ("Clip", Range(0,2)) = 0.5
- _BandColor ("BandColor", Color) = (1,1,1,1)
- _BandWidth ("BandWidth", Range(0,1)) = 0.1
- _BrightnessHack ("Brightness", Range(0,10)) = 2.05
-}
-	//DummyShaderTextExporter
-	
-	SubShader{
-		Tags { "RenderType" = "Opaque" }
-		LOD 200
-		CGPROGRAM
-#pragma surface surf Lambert
-#pragma target 3.0
-		sampler2D _MainTex;
-		struct Input
-		{
-			float2 uv_MainTex;
-		};
-		void surf(Input IN, inout SurfaceOutput o)
-		{
-			float4 c = tex2D(_MainTex, IN.uv_MainTex);
-			o.Albedo = c.rgb;
-		}
-		ENDCG
-	}
+    Properties {
+        _Color ("Color", Color) = (1,1,1,1)
+        _SpecColor ("Specular Color", Color) = (0.5,0.5,0.5,0)
+        _Shininess ("Shininess", Range(0.01,1)) = 0.078125
+        _MainTex ("Base (RGB) Gloss(A)", 2D) = "white" { }
+        _Normal ("Normal", 2D) = "bump" { }
+        _Emissive ("Emissive", 2D) = "black" { }
+        _ClipTexture ("ClipTexture", 2D) = "white" { }
+        _Clip ("Clip", Range(0,2)) = 0.5
+        _BandColor ("BandColor", Color) = (1,1,1,1)
+        _BandWidth ("BandWidth", Range(0,1)) = 0.1
+        _BrightnessHack ("Brightness", Range(0,10)) = 2.05
+    }
+
+    SubShader { 
+        LOD 400
+        Tags { 
+            "QUEUE"="AlphaTest" 
+            "RenderType"="TransparentCutout" 
+        }
+        
+        CGPROGRAM
+        // Use BlinnPhong lighting, generate all forward & deferred passes, and inject custom shadow caster
+        #pragma surface surf BlinnPhong addshadow fullforwardshadows
+        #pragma target 3.0
+
+        struct Input {
+            float2 uv_MainTex;
+            float2 uv_Normal;
+            float2 uv_Emissive;
+            float3 worldPos;
+        };
+
+        sampler2D _MainTex;
+        sampler2D _Normal;
+        sampler2D _Emissive;
+        sampler2D _ClipTexture;
+        
+        float4 _ClipTexture_ST;
+        
+        fixed4 _Color;
+        fixed4 _BandColor;
+        half _Shininess;
+        fixed _Clip;
+        fixed _BandWidth;
+        half _BrightnessHack;
+
+        void surf (Input IN, inout SurfaceOutput o) {
+            // 1. World-Space XZ Dissolve UV mapping
+            float2 clipUV = IN.worldPos.xz * _ClipTexture_ST.xy + _ClipTexture_ST.zw;
+            
+            // 2. Read clipping map value
+            float clipTexVal = tex2D(_ClipTexture, clipUV).r;
+            float clipVal = clipTexVal + _Clip;
+            
+            // 3. Discard threshold (Alpha Test cutout)
+            clip(clipVal - 1.0);
+            
+            // 4. Band Logic
+            // Evaluates to 1.0 outside the band limit, and 0.0 on the burn edge band itself.
+            float isNotBand = step(_BandWidth, clipVal - 1.0);
+            float isBand = 1.0 - isNotBand;
+            
+            fixed4 tex = tex2D(_MainTex, IN.uv_MainTex);
+            
+            // 5. Diffuse/Albedo (Blacked out in the band area)
+            o.Albedo = tex.rgb * _Color.rgb * isNotBand * _BrightnessHack;
+            
+            // 6. Gloss/Specular (In the original, specular is interestingly constrained to the edge band only)
+            o.Gloss = tex.a * isBand;
+            o.Specular = _Shininess;
+            
+            // 7. Normal Map
+            o.Normal = UnpackNormal(tex2D(_Normal, IN.uv_Normal));
+            
+            // 8. Emissive & Glowing Edge Band
+            fixed3 emissive = tex2D(_Emissive, IN.uv_Emissive).rgb;
+            o.Emission = emissive + (_BandColor.rgb * isBand);
+            
+            o.Alpha = 1.0;
+        }
+        ENDCG
+    }
+    
+    FallBack "Transparent/Cutout/VertexLit"
