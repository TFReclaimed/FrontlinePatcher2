diff --git a/Assets/Shader/BlendAddTwoLayer.shader b/Assets/Shader/BlendAddTwoLayer.shader
index 32d9385a..e417e259 100644
--- a/Assets/Shader/BlendAddTwoLayer.shader
+++ b/Assets/Shader/BlendAddTwoLayer.shader
@@ -1,28 +1,115 @@
 Shader "PC/VFX/BlendAddTwoLayer" {
-Properties {
- _Color ("Color", Color) = (1,1,1,1)
- _BlendColor ("BlendColor", Color) = (1,1,1,1)
- _MainTex ("Main", 2D) = "white" { }
- _BlendTex ("Blend", 2D) = "white" { }
-}
-	//DummyShaderTextExporter
-	
-	SubShader{
-		Tags { "RenderType" = "Opaque" }
-		LOD 200
-		CGPROGRAM
-#pragma surface surf Lambert
-#pragma target 3.0
-		sampler2D _MainTex;
-		struct Input
-		{
-			float2 uv_MainTex;
-		};
-		void surf(Input IN, inout SurfaceOutput o)
-		{
-			float4 c = tex2D(_MainTex, IN.uv_MainTex);
-			o.Albedo = c.rgb;
-		}
-		ENDCG
-	}
+    Properties {
+        _Color ("Color", Color) = (1,1,1,1)
+        _BlendColor ("BlendColor", Color) = (1,1,1,1)
+        _MainTex ("Main", 2D) = "white" { }
+        _BlendTex ("Blend", 2D) = "white" { }
+    }
+
+    SubShader {
+        Tags { 
+            "Queue"="Transparent" 
+            "IgnoreProjector"="true" 
+            "RenderType"="Transparent" 
+        }
+        
+        LOD 100
+
+        // --- Pass 1: Alpha Blending ---
+        Pass {
+            Tags { "LightMode"="Always" }
+            ZWrite Off
+            Blend SrcAlpha OneMinusSrcAlpha
+
+            CGPROGRAM
+            #pragma vertex vert
+            #pragma fragment frag
+            #include "UnityCG.cginc"
+
+            struct appdata {
+                float4 vertex : POSITION;
+                float4 color : COLOR;
+                float2 texcoord : TEXCOORD0;
+            };
+
+            struct v2f {
+                float4 pos : SV_POSITION;
+                float2 uv : TEXCOORD0;
+                fixed vertexAlpha : TEXCOORD1;
+            };
+
+            sampler2D _BlendTex;
+            float4 _BlendTex_ST;
+            fixed4 _BlendColor;
+
+            v2f vert (appdata v) {
+                v2f o;
+                o.pos = UnityObjectToClipPos(v.vertex);
+                o.uv = TRANSFORM_TEX(v.texcoord, _BlendTex);
+                // The decompiled code specifically passes vertex color alpha (w)
+                o.vertexAlpha = v.color.a;
+                return o;
+            }
+
+            fixed4 frag (v2f i) : SV_Target {
+                fixed4 tex = tex2D(_BlendTex, i.uv);
+                fixed4 col = tex * _BlendColor;
+                // Multiply final alpha by vertex alpha
+                col.a *= i.vertexAlpha;
+                return col;
+            }
+            ENDCG
+        }
+
+        // --- Pass 2: Additive Layer ---
+        Pass {
+            Tags { "LightMode"="Always" }
+            ZWrite Off
+            Blend One One // Additive
+
+            CGPROGRAM
+            #pragma vertex vert
+            #pragma fragment frag
+            #include "UnityCG.cginc"
+
+            struct appdata {
+                float4 vertex : POSITION;
+                float4 color : COLOR; // Uses R and G channels
+                float2 texcoord : TEXCOORD0;
+            };
+
+            struct v2f {
+                float4 pos : SV_POSITION;
+                float2 uv : TEXCOORD0;
+                fixed2 vertexRG : TEXCOORD1;
+            };
+
+            sampler2D _MainTex;
+            float4 _MainTex_ST;
+            fixed4 _Color;
+
+            v2f vert (appdata v) {
+                v2f o;
+                o.pos = UnityObjectToClipPos(v.vertex);
+                o.uv = TRANSFORM_TEX(v.texcoord, _MainTex);
+                // Decompiled code uses vertex.xy (R and G) for weighting
+                o.vertexRG = v.color.rg;
+                return o;
+            }
+
+            fixed4 frag (v2f i) : SV_Target {
+                fixed4 tex = tex2D(_MainTex, i.uv);
+                
+                /* 
+                   Decompiled logic:
+                   addColor = ((tex.rgb * vertexColor.r) + (_Color.rgb * vertexColor.g)) * tex.a
+                */
+                half3 addColor = (tex.rgb * i.vertexRG.x) + (_Color.rgb * i.vertexRG.y);
+                addColor *= tex.a;
+
+                return fixed4(addColor, 0.0);
+            }
+            ENDCG
+        }
+    }
 }
