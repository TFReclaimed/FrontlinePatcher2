+                o.uv = v.uv;
+
+                // This reproduces the pulse logic:
+                // It creates a sawtooth pulse that goes from 1.0 down to 0.5 
+                // and snaps back to 1.0 every second.
+                o.pulse = 1.0 - (frac(_Time.y) * 0.5);
+                
+                return o;
+            }
+
+            fixed4 frag (v2f i) : SV_Target {
+                // Sample the texture
+                fixed4 texColor = tex2D(_MainTex, i.uv);
+                
