+    Properties {
+        _Color ("Color", Color) = (0.0784314, 0.392157, 0.784314, 1)
+        _MainTex ("Texture", 2D) = "white" { }
+    }
+
+    SubShader {
+        Tags { 
+            "Queue"="Transparent" 
+            "IgnoreProjector"="true" 
+            "RenderType"="Transparent" 
+        }
+
+        Pass {
+            Name "FORWARD"
+            Tags { "LightMode"="ForwardBase" }
+            
+            ZWrite Off
+            Cull Off
+            // Blend One One is Additive blending (Color + Background)
+            Blend One One 
+
+            HLSLPROGRAM
+            #pragma vertex vert
+            #pragma fragment frag
+            #include "UnityCG.cginc"
+
+            struct appdata {
+                float4 vertex : POSITION;
+                float2 uv : TEXCOORD0;
+            };
+
+            struct v2f {
+                float4 pos : SV_POSITION;
+                float2 uv : TEXCOORD0;
+                float pulse : TEXCOORD1;
+            };
