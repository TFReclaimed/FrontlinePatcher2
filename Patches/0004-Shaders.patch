 Shader "vfx/UIPulse" {
-Properties {
- _Color ("Color", Color) = (0.0784314,0.392157,0.784314,1)
- _MainTex ("texture", 2D) = "white" { }
-}
-	//DummyShaderTextExporter
-	
-	SubShader{
-		Tags { "RenderType" = "Opaque" }
