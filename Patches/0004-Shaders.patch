+            {
+                // Ensure vectors are normalized before calculating dot product
+                float3 normal = normalize(i.worldNormal);
+                float3 lightDir = normalize(_WorldSpaceLightPos0.xyz);
+
+                // Calculate the lighting intensity (N dot L), clamped between 0 and 1
+                float NdotL = saturate(dot(normal, lightDir));
+
+                // Apply power and multiply by the color property
+                float3 color = _Color.rgb * pow(NdotL, _Power);
+
+                // Output the result. Alpha is set to 1.0 (since blending is additive, alpha is mostly ignored anyway)
+                return fixed4(color, 1.0);
+            }
+            ENDCG
