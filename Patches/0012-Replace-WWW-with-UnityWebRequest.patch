From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Nuutti <snuutti@protonmail.com>
Date: Thu, 5 Mar 2026 23:59:37 +0200
Subject: [PATCH] Replace WWW with UnityWebRequest


diff --git a/Assets/Scripts/Assembly-CSharp/PerformanceMonitor.cs b/Assets/Scripts/Assembly-CSharp/PerformanceMonitor.cs
index 182dd89b..7038f5ec 100644
--- a/Assets/Scripts/Assembly-CSharp/PerformanceMonitor.cs
+++ b/Assets/Scripts/Assembly-CSharp/PerformanceMonitor.cs
@@ -445,3 +445,3 @@ public class PerformanceMonitor : SingletonMonoBehaviour<PerformanceMonitor>
 			pingTimer = 0f;
-			Singleton<WWWManager>.Instance.RequestText(GameShell.GetServerInterface().GetServerAddress() + "/session/ping", OnPingComplete);
+			Singleton<WWWManager>.Instance.RequestText(GameShell.GetServerInterface().GetServerAddress() + "session/ping", OnPingComplete);
 		}
diff --git a/Assets/Scripts/Assembly-CSharp/ServerInterface.cs b/Assets/Scripts/Assembly-CSharp/ServerInterface.cs
index 0564662f..98fc5a64 100644
--- a/Assets/Scripts/Assembly-CSharp/ServerInterface.cs
+++ b/Assets/Scripts/Assembly-CSharp/ServerInterface.cs
@@ -9,2 +9,3 @@ using hg.ApiWebKit;
 using hg.ApiWebKit.core.http;
+using UnityEngine.Networking;
 
@@ -74,3 +75,3 @@ public class ServerInterface
 
-		public WWW requestInflight;
+		public UnityWebRequest requestInflight;
 
@@ -167,3 +168,3 @@ public class ServerInterface
 			new ApiConfigInfo("init/", true, false, false),
-			new ApiConfigInfo("session/info", false, true, false),
+			new ApiConfigInfo("session/info", true, true, false),
 			new ApiConfigInfo("session/bundles/", true, true, true),
@@ -591,14 +592,2 @@ public class ServerInterface
 
-	public short ProcessHttpStatus(Dictionary<string, string> responseHeaders)
-	{
-		short result = 500;
-		if (responseHeaders.Count > 0)
-		{
-			string text = responseHeaders["STATUS"];
-			string s = text.Substring(9, 3);
-			result = short.Parse(s);
-		}
-		return result;
-	}
-
 	protected void CleanupPostResponse(RequestChannelInfo channel)
@@ -622,7 +611,7 @@ public class ServerInterface
 		}
-		Dictionary<string, string> responseHeaders = requestedChannel.requestInflight.responseHeaders;
-		short num = ProcessHttpStatus(responseHeaders);
-		if (flag && responseHeaders.Count > 0 && requestedChannel.requestInflight.bytes.Length > 0)
+		Dictionary<string, string> responseHeaders = requestedChannel.requestInflight.GetResponseHeaders();
+		short num = (short)requestedChannel.requestInflight.responseCode;
+		if (flag && responseHeaders != null && responseHeaders.Count > 0 && requestedChannel.requestInflight.downloadedBytes > 0)
 		{
-			text = requestedChannel.requestInflight.text;
+			text = requestedChannel.requestInflight.downloadHandler.text;
 		}
@@ -687,3 +676,3 @@ public class ServerInterface
 		{
-			byte[] postData = null;
+			string postData = null;
 			if (requestedChannel.requestParams != null)
@@ -692,3 +681,3 @@ public class ServerInterface
 				{
-					string text = WWW.EscapeURL(requestedChannel.requestParams);
+					string text = UnityWebRequest.EscapeURL(requestedChannel.requestParams);
 					stringBuilder.Append("?param=" + text);
@@ -698,3 +687,3 @@ public class ServerInterface
 					string s = "param=" + requestedChannel.requestParams;
-					postData = Encoding.UTF8.GetBytes(s);
+					postData = s;
 				}
@@ -702,3 +691,18 @@ public class ServerInterface
 			GameDebug.Info("Sending Request to Channel " + channelIndex + ":  " + stringBuilder.ToString());
-			requestedChannel.requestInflight = new WWW(stringBuilder.ToString(), postData, requestHeaders);
+			UnityWebRequest uwr;
+			if (apiConfigInfo.isGet)
+			{
+				uwr = UnityWebRequest.Get(stringBuilder.ToString());
+			}
+			else
+			{
+				uwr = UnityWebRequest.Post(stringBuilder.ToString(), postData, "application/x-www-form-urlencoded");
+			}
+			uwr.downloadHandler = new DownloadHandlerBuffer();
+			foreach (KeyValuePair<string, string> header in requestHeaders)
+			{
+				uwr.SetRequestHeader(header.Key, header.Value);
+			}
+			uwr.SendWebRequest();
+			requestedChannel.requestInflight = uwr;
 			FireRequestStartedNotification((Channel)channelIndex, requestedChannel);
diff --git a/Assets/Scripts/Assembly-CSharp/WWWRequest.cs b/Assets/Scripts/Assembly-CSharp/WWWRequest.cs
index 33ae90fe..d72b9fcd 100644
--- a/Assets/Scripts/Assembly-CSharp/WWWRequest.cs
+++ b/Assets/Scripts/Assembly-CSharp/WWWRequest.cs
@@ -4,2 +4,3 @@ using System.Diagnostics;
 using UnityEngine;
+using UnityEngine.Networking;
 
@@ -23,3 +24,3 @@ public class WWWRequest
 
-	private WWW request;
+	private UnityWebRequest request;
 
@@ -31,2 +32,4 @@ public class WWWRequest
 
+	private ulong lastDownloadedBytes;
+
 	private float progressTimestamp;
@@ -95,3 +98,3 @@ public class WWWRequest
 		{
-			return request.bytesDownloaded;
+			return (int) request.downloadedBytes;
 		}
@@ -103,3 +106,3 @@ public class WWWRequest
 		{
-			return (request == null) ? 0f : request.progress;
+			return (request == null) ? 0f : request.downloadProgress;
 		}
@@ -113,3 +116,3 @@ public class WWWRequest
 		{
-			return (request == null) ? null : request.assetBundle;
+			return (request == null) ? null : DownloadHandlerAssetBundle.GetContent(request);
 		}
@@ -121,3 +124,3 @@ public class WWWRequest
 		{
-			return (request == null) ? null : request.text;
+			return (request == null || !request.isDone) ? null : request.downloadHandler.text;
 		}
@@ -147,2 +150,4 @@ public class WWWRequest
 		}
+		lastProgress = 0f;
+		lastDownloadedBytes = 0;
 		progressTimestamp = Time.realtimeSinceStartup;
@@ -155,3 +160,4 @@ public class WWWRequest
 			{
-				request = WWW.LoadFromCacheOrDownload(URI, 0, CRC);
+				var version = CRC == 0 ? 0 : CRC;
+				request = UnityWebRequestAssetBundle.GetAssetBundle(URI, version, CRC);
 			}
@@ -159,7 +165,27 @@ public class WWWRequest
 			{
-				request = new WWW(URI);
+				request = UnityWebRequestAssetBundle.GetAssetBundle(URI);
 			}
+
+			request.SendWebRequest();
 			break;
 		case DataType.Text:
-			request = new WWW(URI, PostData, Headers);
+			if (PostData == null)
+			{
+				request = new UnityWebRequest(URI, "GET");
+			}
+			else
+			{
+				request = new UnityWebRequest(URI, "POST");
+			}
+			
+			if (Headers != null)
+			{
+				foreach (var header in Headers)
+				{
+					request.SetRequestHeader(header.Key, header.Value);
+				}
+			}
+			
+			request.downloadHandler = new DownloadHandlerBuffer();
+			request.SendWebRequest();
 			break;
@@ -173,9 +199,9 @@ public class WWWRequest
 		{
-			if (IsDone)
+			if (!string.IsNullOrEmpty(request.error))
 			{
-				time.Stop();
+				Fail(request.error);
 			}
-			else if (!string.IsNullOrEmpty(request.error))
+			else if (IsDone)
 			{
-				Fail(request.error);
+				time.Stop();
 			}
@@ -215,3 +241,4 @@ public class WWWRequest
 		float realtimeSinceStartup = Time.realtimeSinceStartup;
-		if (lastProgress == request.progress)
+		ulong downloadedBytes = request.downloadedBytes;
+		if (lastProgress == request.downloadProgress && lastDownloadedBytes == downloadedBytes)
 		{
@@ -230,3 +257,4 @@ public class WWWRequest
 		{
-			lastProgress = request.progress;
+			lastProgress = request.downloadProgress;
+			lastDownloadedBytes = downloadedBytes;
 			progressTimestamp = realtimeSinceStartup;
