Subject: [PATCH] Android target refresh rate


diff --git a/Assets/Scripts/Assembly-CSharp/GameShell.cs b/Assets/Scripts/Assembly-CSharp/GameShell.cs
index 76bd867a..c48d6aa3 100644
--- a/Assets/Scripts/Assembly-CSharp/GameShell.cs
+++ b/Assets/Scripts/Assembly-CSharp/GameShell.cs
@@ -149,2 +149,6 @@ public class GameShell : SingletonMonoBehaviour<GameShell>, INPListenerType, INP
 		screenHeight = Screen.height;
+#if UNITY_ANDROID
+		// Unity limits FPS to 30 on Android by default
+		Application.targetFrameRate = (int) Screen.currentResolution.refreshRateRatio.value;
+#endif
 	}
