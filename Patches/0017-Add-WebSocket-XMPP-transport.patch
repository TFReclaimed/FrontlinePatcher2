diff --git a/Assets/Scripts/Assembly-CSharp/XmppWebSocketTransport.cs b/Assets/Scripts/Assembly-CSharp/XmppWebSocketTransport.cs
new file mode 100644
index 00000000..e3baaf7c
--- /dev/null
+++ b/Assets/Scripts/Assembly-CSharp/XmppWebSocketTransport.cs
@@ -0,0 +1,149 @@
+#if UNITY_WEBGL
+using System;
+using System.Reactive.Subjects;
+using System.Text;
+using System.Threading;
+using System.Threading.Tasks;
+using NativeWebSocket;
+using UnityEngine;
+using XmppDotNet.Transport;
+using XmppDotNet.Xml;
+using XmppDotNet.Xmpp.Client;
+
+public class XmppWebSocketTransport : ITransport
+{
+    private readonly ISubject<XmppXElement> _xmlReceivedSubject = new Subject<XmppXElement>();
+    private readonly ISubject<XmppXElement> _beforeXmlSentSubject = new Subject<XmppXElement>();
+    private readonly ISubject<XmppXElement> _xmlSentSubject = new Subject<XmppXElement>();
+    private readonly ISubject<byte[]> _dataReceivedSubject = new Subject<byte[]>();
+    private readonly ISubject<byte[]> _dataSentSubject = new Subject<byte[]>();
+    private readonly TransportState _transportStateSubject = new();
+
+    private WebSocket _webSocket;
+    private bool _streamFooterSent;
+
+    public IObservable<XmppXElement> XmlReceived => _xmlReceivedSubject;
+    public IObservable<XmppXElement> BeforeXmlSent => _beforeXmlSentSubject;
+    public IObservable<XmppXElement> XmlSent => _xmlSentSubject;
+    public IObservable<byte[]> DataReceived => _dataReceivedSubject;
+    public IObservable<byte[]> DataSent => _dataSentSubject;
+    public IObservable<State> StateChanged => _transportStateSubject.ValueChanged;
+    public IResolver Resolver { get; set; }
+    public bool SupportsStartTls => false;
+
+    public Task ConnectAsync(string xmppDomain)
+    {
+        var tcs = new TaskCompletionSource<bool>();
+
+        _webSocket = new WebSocket("ws://127.0.0.1:10000/chat", "xmpp");
+        _webSocket.OnOpen += OnOpen;
+        _webSocket.OnOpen += () => tcs.TrySetResult(true);
+        _webSocket.OnError += OnError;
+        _webSocket.OnError += errorMsg => tcs.TrySetException(new Exception(errorMsg));
+        _webSocket.OnClose += OnClose;
+        _webSocket.OnMessage += OnMessage;
+
+        _streamFooterSent = false;
+
+        _ = _webSocket.Connect();
+        return tcs.Task;
+    }
+
+    public async Task DisconnectAsync()
+    {
+        try
+        {
+            await _webSocket.Close();
+        }
+        catch (Exception ex)
+        {
+            Debug.LogError($"Error closing WebSocket: {ex}");
+        }
+        finally
+        {
+            _transportStateSubject.Value = State.Disconnected;
+        }
+    }
+
+    public async Task SendAsync(XmppXElement xmppXElement)
+    {
+        await SendAsync(xmppXElement, CancellationToken.None);
+    }
+
+    public async Task SendAsync(XmppXElement xmppXElement, CancellationToken cancellationToken)
+    {
+        _beforeXmlSentSubject.OnNext(xmppXElement);
+
+        var bytes = Encoding.UTF8.GetBytes(xmppXElement.ToString());
+        await _webSocket.Send(bytes);
+
+        if (xmppXElement.OfType<Stream>() && xmppXElement.Cast<Stream>().IsEndTag)
+        {
+            _transportStateSubject.Value = State.StreamFooterSent;
+            _streamFooterSent = true;
+        }
+
+        _dataSentSubject.OnNext(bytes);
+        _xmlSentSubject.OnNext(xmppXElement);
+    }
+
+    public Task InitTls(string xmppDomain)
+    {
+        throw new NotImplementedException();
+    }
+
+    public XmppXElement GetStreamHeader(string to, string version)
+    {
+        return new Stream
+        {
+            To = to,
+            Version = version
+        };
+    }
+
+    public XmppXElement GetStreamFooter()
+    {
+        return new Stream
+        {
+            IsEndTag = true
+        };
+    }
+
+    private void OnOpen()
+    {
+        _transportStateSubject.Value = State.Connected;
+    }
+
+    private void OnError(string errorMsg)
+    {
+        Debug.LogError($"WebSocket error: {errorMsg}");
+        _ = DisconnectAsync();
+    }
+
+    private void OnClose(WebSocketCloseCode closeCode)
+    {
+        Debug.Log($"WebSocket closed with code: {closeCode}");
+        _transportStateSubject.Value = State.Disconnected;
+    }
+
+    private void OnMessage(byte[] data)
+    {
+        _dataReceivedSubject.OnNext(data);
+
+        var xml = Encoding.UTF8.GetString(data);
+        var element = XmppXElement.LoadXml(xml);
+
+        _xmlReceivedSubject.OnNext(element);
+
+        if (element.OfType<Stream>() && element.Cast<Stream>().IsEndTag)
+        {
+            _transportStateSubject.Value = State.StreamFooterReceived;
+            if (!_streamFooterSent)
+            {
+                _ = SendAsync(GetStreamFooter());
+            }
+        }
+    }
+}
+#endif
+
