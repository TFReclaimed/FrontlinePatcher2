From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Nuutti <snuutti@protonmail.com>
Date: Sat, 28 Mar 2026 17:19:22 +0200
Subject: [PATCH] Tweak AssetBundle caching

Stores AssetBundles as uncompressed.

On modern Linux distros the default AssetBundle cache location /tmp is mounted as a RAM disk, so use persistent data path instead.

diff --git a/Assets/Scripts/Assembly-CSharp/AssetManager.cs b/Assets/Scripts/Assembly-CSharp/AssetManager.cs
index 5bd83213..b4754007 100644
--- a/Assets/Scripts/Assembly-CSharp/AssetManager.cs
+++ b/Assets/Scripts/Assembly-CSharp/AssetManager.cs
@@ -122,2 +122,17 @@ public class AssetManager : Singleton<AssetManager>
 		Caching.maximumAvailableDiskSpace = MAX_CACHE_SPACE;
+		Caching.compressionEnabled = false;
+		var cachePath = Path.Combine(Application.persistentDataPath, "Bundles");
+		if (!Directory.Exists(cachePath))
+		{
+			Directory.CreateDirectory(cachePath);
+		}
+		var newCache = Caching.AddCache(cachePath);
+		if (newCache.valid)
+		{
+			Caching.currentCacheForWriting = newCache;
+		}
+		else
+		{
+			GameDebug.Error("Failed to create AssetBundle cache at {0}", cachePath);
+		}
 		if (UseLocalBundles)
