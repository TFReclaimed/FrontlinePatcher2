From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Nuutti <snuutti@protonmail.com>
Date: Thu, 30 Apr 2026 01:01:09 +0300
Subject: [PATCH] Fix float parsing on some languages


diff --git a/Assets/Scripts/Assembly-CSharp/PvE/ConditionalData.cs b/Assets/Scripts/Assembly-CSharp/PvE/ConditionalData.cs
index 2593fee7..be4596b3 100644
--- a/Assets/Scripts/Assembly-CSharp/PvE/ConditionalData.cs
+++ b/Assets/Scripts/Assembly-CSharp/PvE/ConditionalData.cs
@@ -2,2 +2,3 @@ using System;
 using System.Collections.Generic;
+using System.Globalization;
 using UnityEngine;
@@ -180,3 +181,3 @@ namespace PvE
 				float result = 0f;
-				if (!float.TryParse(Comparison, out result))
+				if (!float.TryParse(Comparison, NumberStyles.Float, CultureInfo.InvariantCulture, out result))
 				{
diff --git a/Assets/Scripts/Assembly-CSharp/PvE/MissionEffect.cs b/Assets/Scripts/Assembly-CSharp/PvE/MissionEffect.cs
index 4802424d..c6182d5b 100644
--- a/Assets/Scripts/Assembly-CSharp/PvE/MissionEffect.cs
+++ b/Assets/Scripts/Assembly-CSharp/PvE/MissionEffect.cs
@@ -1,2 +1,3 @@
 using System;
+using System.Globalization;
 
@@ -57,3 +58,3 @@ namespace PvE
 						float result;
-						if (float.TryParse(array[1], out result))
+						if (float.TryParse(array[1], NumberStyles.Float, CultureInfo.InvariantCulture, out result))
 						{
diff --git a/Assets/Scripts/Assembly-CSharp/PvE/TemplateRow.cs b/Assets/Scripts/Assembly-CSharp/PvE/TemplateRow.cs
index b40422a8..680150af 100644
--- a/Assets/Scripts/Assembly-CSharp/PvE/TemplateRow.cs
+++ b/Assets/Scripts/Assembly-CSharp/PvE/TemplateRow.cs
@@ -2,2 +2,3 @@ using System;
 using System.Collections.Generic;
+using System.Globalization;
 using UnityEngine;
@@ -145,3 +146,3 @@ namespace PvE
 			float result;
-			if (float.TryParse(value, out result))
+			if (float.TryParse(value, NumberStyles.Float, CultureInfo.InvariantCulture, out result))
 			{
