From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Nuutti <snuutti@protonmail.com>
Date: Sat, 28 Mar 2026 20:44:46 +0200
Subject: [PATCH] Fix character UI bugs

Fixes exception and broken guild button when opening profile of user not in guild.

diff --git a/Assets/Scripts/Assembly-CSharp/CharacterUI.cs b/Assets/Scripts/Assembly-CSharp/CharacterUI.cs
index 6246dba9..ef4ebbbb 100644
--- a/Assets/Scripts/Assembly-CSharp/CharacterUI.cs
+++ b/Assets/Scripts/Assembly-CSharp/CharacterUI.cs
@@ -2,2 +2,3 @@ using System;
 using System.Collections;
+using System.Linq;
 using TMPro;
@@ -319,9 +320,9 @@ public class CharacterUI : MonoBehaviour
 		}
-		SingletonMonoBehaviour<AvatarManager>.Instance.RequestAvatarSprite(playerDetails.avatarId, delegate(string aID, Sprite sprite)
+		if (playerDetails != null)
 		{
-			CharacterImage.sprite = sprite;
-		});
-		ChallengeButton.gameObject.SetActive(false);
-		InviteButton.gameObject.SetActive(false);
-		MessageButton.gameObject.SetActive(false);
+			SingletonMonoBehaviour<AvatarManager>.Instance.RequestAvatarSprite(playerDetails.avatarId, delegate(string aID, Sprite sprite)
+			{
+				CharacterImage.sprite = sprite;
+			});
+		}
 		ChallengeButton.gameObject.SetActive(false);
@@ -440,3 +441,3 @@ public class CharacterUI : MonoBehaviour
 	{
-		if (_guildProfile != null && profile != null && _guildProfile.id != profile.id)
+		if (_desiredUserId != null && profile != null && profile.members.All(m => m.memberId != _desiredUserId))
 		{
@@ -446,2 +447,3 @@ public class CharacterUI : MonoBehaviour
 		{
+			GuildButton.enabled = false;
 			if (!string.IsNullOrEmpty(_desiredUserId))
