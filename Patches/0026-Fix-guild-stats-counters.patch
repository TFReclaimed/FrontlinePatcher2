Subject: [PATCH] Fix guild stats counters


diff --git a/Assets/Scripts/Assembly-CSharp/GuildMemberRow.cs b/Assets/Scripts/Assembly-CSharp/GuildMemberRow.cs
index 3ec77ddc..5269887e 100644
--- a/Assets/Scripts/Assembly-CSharp/GuildMemberRow.cs
+++ b/Assets/Scripts/Assembly-CSharp/GuildMemberRow.cs
@@ -6,2 +6,4 @@ public class GuildMemberRow : MonoBehaviour
 {
+	public delegate void ProfileLoaded(PlayerProfile.Details profile);
+
 	public AvatarImage PlayerAvatar;
@@ -31,2 +33,6 @@ public class GuildMemberRow : MonoBehaviour
 
+	public ProfileLoaded OnProfileLoaded;
+
+	public PlayerProfile.Details Profile;
+
 	protected string _userId;
@@ -92,2 +98,3 @@ public class GuildMemberRow : MonoBehaviour
 		}
+		Profile = profile;
 		if ((bool)OnlineStatus && (bool)SingletonMonoBehaviour<ChatManager>.Instance)
@@ -103,2 +110,6 @@ public class GuildMemberRow : MonoBehaviour
 		}
+		if (OnProfileLoaded != null)
+		{
+			OnProfileLoaded(profile);
+		}
 	}
diff --git a/Assets/Scripts/Assembly-CSharp/GuildUI.cs b/Assets/Scripts/Assembly-CSharp/GuildUI.cs
index a51dd6fe..9487de00 100644
--- a/Assets/Scripts/Assembly-CSharp/GuildUI.cs
+++ b/Assets/Scripts/Assembly-CSharp/GuildUI.cs
@@ -152,2 +152,4 @@ public class GuildUI : MonoBehaviour
 	{
+		TotalMemberWins.text = "0";
+		CardsCollected.text = "0";
 		UpdateGuildInfo();
@@ -353,2 +355,3 @@ public class GuildUI : MonoBehaviour
 			row.gameObject.SetActive(true);
+			row.OnProfileLoaded += OnGuildMemberProfileReceived;
 		}
@@ -360,6 +363,25 @@ public class GuildUI : MonoBehaviour
 
+	private void OnGuildMemberProfileReceived(PlayerProfile.Details profile)
+	{
+		var memberWins = 0;
+		var cardsCollected = 0;
+		foreach (var memberRow in _memberRows)
+		{
+			if (!memberRow.gameObject.activeSelf)
+			{
+				continue;
+			}
+
+			if (memberRow.Profile != null)
+			{
+				memberWins += memberRow.Profile.Wins;
+				cardsCollected += memberRow.Profile.CardsCollected;
+			}
+		}
+		TotalMemberWins.text = memberWins.ToString();
+		CardsCollected.text = cardsCollected.ToString();
+	}
+
 	protected void UpdateGuildStats()
 	{
-		TotalMemberWins.text = "0";
-		CardsCollected.text = "0";
 		StringBuilder stringBuilder = new StringBuilder();
