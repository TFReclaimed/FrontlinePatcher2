diff --git a/Assets/Scripts/Assembly-CSharp/Letterboxing.cs b/Assets/Scripts/Assembly-CSharp/Letterboxing.cs
new file mode 100644
index 00000000..dda1b3db
--- /dev/null
+++ b/Assets/Scripts/Assembly-CSharp/Letterboxing.cs
@@ -0,0 +1,64 @@
+using UnityEngine;
+
+[RequireComponent(typeof(RectTransform))]
+public class Letterboxing : MonoBehaviour
+{
+#if UNITY_ANDROID || UNITY_IOS
+    private const float TargetAspect = 9f / 16f;
+
+    private RectTransform _rectTransform;
+
+    private Rect _lastSafeArea = new(0, 0, 0, 0);
+
+    private Vector2 _lastScreenSize = new(0, 0);
+
+    private void Awake()
+    {
+        _rectTransform = GetComponent<RectTransform>();
+    }
+
+    private void Update()
+    {
+        if (_lastSafeArea != Screen.safeArea || _lastScreenSize.x != Screen.width || _lastScreenSize.y != Screen.height)
+        {
+            ApplyLayout();
+        }
+    }
+
+    private void ApplyLayout()
+    {
+        _lastSafeArea = Screen.safeArea;
+        _lastScreenSize = new Vector2(Screen.width, Screen.height);
+
+        var anchorMinX = _lastSafeArea.x / _lastScreenSize.x;
+        var anchorMinY = _lastSafeArea.y / _lastScreenSize.y;
+        var anchorMaxX = (_lastSafeArea.x + _lastSafeArea.width) / _lastScreenSize.x;
+        var anchorMaxY = (_lastSafeArea.y + _lastSafeArea.height) / _lastScreenSize.y;
+
+        var safeWidth = _lastSafeArea.width;
+        var safeHeight = _lastSafeArea.height;
+        var safeAspect = safeWidth / safeHeight;
+
+        if (safeAspect > TargetAspect)
+        {
+            var inset = 1f - TargetAspect / safeAspect;
+            var margin = (anchorMaxX - anchorMinX) * (inset / 2f);
+            anchorMinX += margin;
+            anchorMaxX -= margin;
+        }
+        else
+        {
+            var inset = 1f - safeAspect / TargetAspect;
+            var margin = (anchorMaxY - anchorMinY) * (inset / 2f);
+            anchorMinY += margin;
+            anchorMaxY -= margin;
+        }
+
+        _rectTransform.anchorMin = new Vector2(anchorMinX, anchorMinY);
+        _rectTransform.anchorMax = new Vector2(anchorMaxX, anchorMaxY);
+
+        _rectTransform.offsetMin = Vector2.zero;
+        _rectTransform.offsetMax = Vector2.zero;
+    }
+#endif
+}
