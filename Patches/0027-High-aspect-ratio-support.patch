diff --git a/Assets/Scripts/Assembly-CSharp/CameraAspectRatio.cs b/Assets/Scripts/Assembly-CSharp/CameraAspectRatio.cs
new file mode 100644
index 00000000..c5bd7aff
--- /dev/null
+++ b/Assets/Scripts/Assembly-CSharp/CameraAspectRatio.cs
@@ -0,0 +1,15 @@
+using UnityEngine;
+
+public class CameraAspectRatio : MonoBehaviour
+{
+    private void Update()
+    {
+        var aspectRatio = (float) Screen.width / Screen.height;
+        const float maxRatio = 9f / 16f;
+        var constrainedRatio = Mathf.Min(aspectRatio, maxRatio);
+        var newZ = 1.73f + 3.85f / constrainedRatio - 3.06f / (constrainedRatio * constrainedRatio);
+        var position = transform.localPosition;
+        position.z = newZ;
+        transform.localPosition = position;
+    }
+}
