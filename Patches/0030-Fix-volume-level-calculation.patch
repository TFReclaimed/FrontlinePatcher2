From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Nuutti <snuutti@protonmail.com>
Date: Tue, 21 Apr 2026 22:32:42 +0300
Subject: [PATCH] Fix volume level calculation


diff --git a/Assets/Scripts/Assembly-CSharp/GameShell.cs b/Assets/Scripts/Assembly-CSharp/GameShell.cs
index ef6646f4..599c9501 100644
--- a/Assets/Scripts/Assembly-CSharp/GameShell.cs
+++ b/Assets/Scripts/Assembly-CSharp/GameShell.cs
@@ -407,5 +407,5 @@ public class GameShell : SingletonMonoBehaviour<GameShell>, INPListenerType, INP
 			SettingsManager instance = SingletonMonoBehaviour<SettingsManager>.Instance;
-			float value = ((!instance.allMuted) ? instance.masterVolume : 0f) * 80f - 80f;
-			float value2 = ((!instance.musicMuted) ? instance.musicVolume : 0f) * 100f - 80f;
-			float value3 = ((!instance.sfxMuted) ? instance.sfxVolume : 0f) * 100f - 80f;
+			float value = Mathf.Max(Mathf.Log10(!instance.allMuted ? instance.masterVolume : 0f) * 20, -80f);
+			float value2 = Mathf.Max(Mathf.Log10(!instance.musicMuted ? instance.musicVolume : 0f) * 20, -80f);
+			float value3 = Mathf.Max(Mathf.Log10(!instance.sfxMuted ? instance.sfxVolume : 0f) * 20, -80f);
 			mixer.SetFloat("MasterVolume", value);
