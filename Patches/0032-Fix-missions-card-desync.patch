From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Nuutti <snuutti@protonmail.com>
Date: Sat, 18 Apr 2026 23:47:42 +0300
Subject: [PATCH] Fix missions card desync


diff --git a/Assets/Scripts/Assembly-CSharp/PvE/PvEClientManager.cs b/Assets/Scripts/Assembly-CSharp/PvE/PvEClientManager.cs
index 233e491c..29c2cc39 100644
--- a/Assets/Scripts/Assembly-CSharp/PvE/PvEClientManager.cs
+++ b/Assets/Scripts/Assembly-CSharp/PvE/PvEClientManager.cs
@@ -208,2 +208,4 @@ namespace PvE
 				Me.RefreshProfileCurrencies();
+				var missionKey = JSON.ToObject<MissionKey>(operation.Key);
+				Me.SetCardStates(missionKey, ePvECardState.OnMission);
 			}
@@ -211,2 +213,41 @@ namespace PvE
 
+		private void SetCardStates(MissionKey key, ePvECardState cardState)
+		{
+			if (!(key != null))
+			{
+				return;
+			}
+			var missionStage = Me.GetMissionStage(key);
+			var cardId = missionStage.GetCardId(eMissionSlotID.Primary);
+			var cardId2 = missionStage.GetCardId(eMissionSlotID.Secondary);
+			var cardId3 = missionStage.GetCardId(eMissionSlotID.Tertiary);
+			var card = Me.GetCard(cardId);
+			var card2 = Me.GetCard(cardId2);
+			var card3 = Me.GetCard(cardId3);
+			if (card != null)
+			{
+				if (card.availability == null)
+				{
+					card.availability = new CardAvailability();
+				}
+				card.availability.PvECardState = cardState;
+			}
+			if (card2 != null)
+			{
+				if (card2.availability == null)
+				{
+					card2.availability = new CardAvailability();
+				}
+				card2.availability.PvECardState = cardState;
+			}
+			if (card3 != null)
+			{
+				if (card3.availability == null)
+				{
+					card3.availability = new CardAvailability();
+				}
+				card3.availability.PvECardState = cardState;
+			}
+		}
+
 		public static Action<OperationMissionStart, HttpResponse> FailedMissionStarted = delegate
