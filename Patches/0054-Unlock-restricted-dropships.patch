From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Nuutti <snuutti@protonmail.com>
Date: Sat, 9 May 2026 23:12:53 +0300
Subject: [PATCH] Unlock restricted dropships


diff --git a/Assets/Scripts/Assembly-CSharp/HangarDropshipPopup.cs b/Assets/Scripts/Assembly-CSharp/HangarDropshipPopup.cs
index d849cc2f..fe966729 100644
--- a/Assets/Scripts/Assembly-CSharp/HangarDropshipPopup.cs
+++ b/Assets/Scripts/Assembly-CSharp/HangarDropshipPopup.cs
@@ -93,3 +93,3 @@ public class HangarDropshipPopup : HangarPopup
 			_customDropships[j].IsLocked = true;
-			_customDropships[j].SetRestricted((j >= 2) ? (-1) : 3);
+			_customDropships[j].SetRestricted((j >= 2) ? (j + 2) : 3);
 		}
diff --git a/Assets/Scripts/Assembly-CSharp/PlayerProfile.cs b/Assets/Scripts/Assembly-CSharp/PlayerProfile.cs
index bdac6d96..28a67815 100644
--- a/Assets/Scripts/Assembly-CSharp/PlayerProfile.cs
+++ b/Assets/Scripts/Assembly-CSharp/PlayerProfile.cs
@@ -187,20 +187,14 @@ public class PlayerProfile
 		{
-			int result = 4;
-			int playerLevel = PlayerLevel;
-			if (playerLevel < 5)
+			return PlayerLevel switch
 			{
-				if (playerLevel == 3)
-				{
-					result = 4;
-				}
-				if (playerLevel == 2)
-				{
-					result = 2;
-				}
-				if (playerLevel < 2)
-				{
-					result = 1;
-				}
-			}
-			return result;
+				8 => 9,
+				7 => 8,
+				6 => 7,
+				5 => 6,
+				4 => 5,
+				3 => 4,
+				2 => 2,
+				< 2 => 1,
+				_ => 10
+			};
 		}
