diff --git a/Assets/Scripts/Assembly-CSharp/DiscordPresenceManager.cs b/Assets/Scripts/Assembly-CSharp/DiscordPresenceManager.cs
new file mode 100644
index 00000000..398de1df
--- /dev/null
+++ b/Assets/Scripts/Assembly-CSharp/DiscordPresenceManager.cs
@@ -0,0 +1,74 @@
+#if UNITY_STANDALONE
+using Lachee.Discord;
+#endif
+using UnityEngine;
+
+public class DiscordPresenceManager : MonoBehaviour
+{
+#if UNITY_STANDALONE
+    private static readonly Asset ImcAsset = new()
+    {
+        image = "commander_spyglass",
+        tooltip = "IMC dropship selected"
+    };
+
+    private static readonly Asset MilitiaAsset = new()
+    {
+        image = "commander_sarah",
+        tooltip = "Militia dropship selected"
+    };
+
+    private float _nextUpdateTime;
+
+    private void Update()
+    {
+        if (AccountManager.profileInfo == null)
+        {
+            return;
+        }
+
+        const float updateInterval = 3f;
+        if (Time.time < _nextUpdateTime)
+        {
+            return;
+        }
+
+        _nextUpdateTime = Time.time + updateInterval;
+
+        var presence = DiscordManager.current.CurrentPresence;
+
+        if (AccountManager.profileInfo.currentGameInstance == ProfileInfo.zeroGameActiveString)
+        {
+            presence.details = "In the menus";
+            presence.state = string.Empty;
+            presence.smallAsset = null;
+        }
+        else if (AccountManager.profileInfo.currentGameInstance == ProfileInfo.gameRequestPending)
+        {
+            presence.details = "Matchmaking";
+            presence.state = string.Empty;
+            presence.smallAsset = null;
+        }
+        else if (GameShell.TheGame() != null)
+        {
+            var gameState = GameShell.TheGame().gameState;
+            presence.details = $"Playing against {gameState.GetRemotePlayer().name}";
+            presence.state = $"Turn {gameState.currentRound + 1}";
+
+            Asset smallAsset;
+            if (gameState.GetLocalPlayer()?.commander?.primaryCard?.GetTemplate()?.faction == Faction.IMC)
+            {
+                smallAsset = ImcAsset;
+            }
+            else
+            {
+                smallAsset = MilitiaAsset;
+            }
+
+            presence.smallAsset = smallAsset;
+        }
+
+        DiscordManager.current.SetPresence(presence);
+    }
+#endif
+}
